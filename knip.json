{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignoreDependencies": [
    "react-19",
    "react-dom-19",
    "@locker/near-membrane-shared-dom",
    "k6",
    "playwright-core",
    "playwright",
    "@rollup/plugin-node-resolve",
    "rollup-plugin-esbuild",
    "rollup-plugin-node-externals",
    "@grafana-plugins/tempo",
    "@grafana-plugins/loki"
  ],
  "ignoreBinaries": ["make", "shellcheck", "wait-on", "jest-canvas-mock-compare-viewer"],
  "ignoreWorkspaces": ["packages/grafana-openapi"],
  "workspaces": {
    ".": {
      "entry": [
        "public/app/plugins/panel/*/module.{ts,tsx}",
        "public/app/plugins/datasource/alertmanager/module.ts",
        "public/app/plugins/datasource/cloudwatch/module.tsx",
        "public/app/plugins/datasource/dashboard/module.ts",
        "public/app/plugins/datasource/grafana/module.ts",
        "public/app/plugins/datasource/mixed/module.ts",
        "public/app/plugins/datasource/prometheus/module.ts",
        "scripts/cli/**/*.{ts,mts}",
        "scripts/codeowners-manifest/*.js",
        "scripts/generate-alerting-rtk-apis.ts",
        "scripts/levitate-parse-json-report.js",
        "scripts/levitate-show-affected-plugins.js",
        "scripts/codemods/*.cjs",
        "scripts/docs/*.ts",
        "scripts/validate-npm-packages.sh",
        "scripts/prepare-npm-package.js",
        "i18next.config.ts"
      ],
      "project": ["public/**/*.{ts,tsx,js,jsx}", "scripts/**/*.{ts,tsx,js,jsx,mts,mjs,cjs}"],
      "ignore": [
        "public/app/extensions/**",
        "public/app/plugins/datasource/azuremonitor/**",
        "public/app/plugins/datasource/cloud-monitoring/**",
        "public/app/plugins/datasource/grafana-postgresql-datasource/**",
        "public/app/plugins/datasource/grafana-pyroscope-datasource/**",
        "public/app/plugins/datasource/grafana-testdata-datasource/**",
        "public/app/plugins/datasource/graphite/**",
        "public/app/plugins/datasource/influxdb/**",
        "public/app/plugins/datasource/jaeger/**",
        "public/app/plugins/datasource/loki/**",
        "public/app/plugins/datasource/mssql/**",
        "public/app/plugins/datasource/mysql/**",
        "public/app/plugins/datasource/opentsdb/**",
        "public/app/plugins/datasource/parca/**",
        "public/app/plugins/datasource/tempo/**"
      ],
      "ignoreDependencies": [
        "@arethetypeswrong/cli",
        "@crowdin/crowdin-api-client",
        "@jest/globals",
        "@types/eslint",
        "@types/react-virtualized-auto-sizer",
        "autoprefixer",
        "jest-junit",
        "jest-monocart-coverage",
        "jimp",
        "open",
        "pdf-parse",
        "postcss-reporter",
        "postcss-scss",
        "publint",
        "smtp-tester"
      ]
    },
    "packages/grafana-plugin-configs": {
      "entry": ["webpack.config.ts", "jest/jest.config.js", "jest/jest-setup.js", "utils.ts", "constants.ts"],
      "webpack": false,
      "ignoreDependencies": [
        "@swc/core",
        "@swc/helpers",
        "@swc/jest",
        "@types/eslint",
        "identity-obj-proxy",
        "imports-loader",
        "jest-canvas-mock",
        "jest-environment-jsdom",
        "swc-loader"
      ]
    },
    "packages/grafana-schema": {
      "entry": [
        "src/schema/dashboard/*/index.ts",
        "src/schema/dashboard/*/*_examples.ts",
        "src/raw/composable/*/panelcfg/x/types.gen.ts",
        "src/raw/composable/*/dataquery/x/types.gen.ts"
      ]
    },
    "packages/grafana-eslint-rules": {},
    "packages/grafana-data": {
      "ignoreDependencies": ["@types/systemjs"]
    },
    "packages/grafana-runtime": {
      "ignoreDependencies": ["@types/systemjs"],
      "ignore": ["src/analytics/plugins/usePluginInteractionReporter.test.tsx"]
    },
    "packages/grafana-alerting": {
      "entry": ["i18next.config.ts"],
      "ignoreDependencies": ["i18next"]
    },
    "packages/grafana-api-clients": {
      "entry": ["src/clients/rtkq/**/index.ts", "src/generator/plopfile.ts", "src/scripts/generate-rtk-apis.ts"]
    },
    "packages/grafana-flamegraph": {
      "ignoreDependencies": ["jest", "ts-jest", "@types/react-virtualized-auto-sizer"]
    },
    "packages/grafana-o11y-ds-frontend": {
      "ignoreDependencies": ["jest", "ts-jest"]
    },
    "packages/grafana-sql": {
      "entry": ["i18next.config.ts"],
      "ignoreDependencies": ["@types/react-virtualized-auto-sizer"]
    },
    "packages/grafana-ui": {
      "ignoreDependencies": [
        "@babel/core",
        "@storybook/mdx2-csf",
        "@types/d3",
        "@types/react-color",
        "expose-loader",
        "process"
      ]
    },
    "public/app/plugins/datasource/*": {
      "entry": ["module.{ts,tsx}"],
      "webpack": false
    },
    "e2e-playwright/test-plugins/*": {
      "entry": ["module.{ts,tsx}"],
      "webpack": false
    }
  }
}
