              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "parameters": [
        {
          "name": "key",
          "in": "path",
          "description": "simulation key (should include hz)",
          "required": true,
          "schema": {
            "type": "string",
            "maxLength": 10
          },
          "examples": {
            "10hz": {
              "summary": "10 times a second",
              "value": "10hz"
            },
            "1hz": {
              "summary": "Once every second",
              "value": "1hz"
            }
          }
        }
      ]
    },
