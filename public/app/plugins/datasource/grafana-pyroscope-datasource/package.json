  "dependencies": {
    "@emotion/css": "catalog:",
    "@grafana/data": "catalog:",
    "@grafana/runtime": "13.0.0-pre",
    "@grafana/schema": "catalog:",
    "@grafana/ui": "catalog:",
    "fast-deep-equal": "catalog:",
    "lodash": "catalog:",
    "monaco-editor": "catalog:",
    "prismjs": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-use": "catalog:",
    "rxjs": "catalog:",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@grafana/e2e-selectors": "catalog:",
    "@grafana/plugin-configs": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/jest": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/prismjs": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "css-loader": "catalog:",
    "jest": "catalog:",
    "style-loader": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:",
    "webpack": "catalog:"
  },
  "peerDependencies": {
    "@grafana/assistant": "*",
    "@grafana/runtime": "*"
  },
  "scripts": {
    "build": "webpack -c ./webpack.config.ts --env production",
    "build:commit": "webpack -c ./webpack.config.ts --env production --env commit=$(git rev-parse --short HEAD)",
    "dev": "webpack -w -c ./webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --maxWorkers 4"
  },
  "packageManager": "yarn@4.11.0"
