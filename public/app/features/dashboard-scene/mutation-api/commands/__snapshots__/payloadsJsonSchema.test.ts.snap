exports[`mutation command payloads — JSON Schema contract listPanels payload JSON Schema is stable 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "List all panels on the dashboard with their layout items",
  "properties": {
    "elements": {
      "description": "Element names to return (e.g. ["panel-1", "panel-5"]). Omit to return all.",
      "items": {
        "type": "string",
      },
      "type": "array",
    },
    "evaluateVariables": {
      "default": false,
      "description": "When true, include evaluatedQueries with template variables resolved to current values",
      "type": "boolean",
    },
    "includeSchema": {
      "default": false,
      "description": "When true, include per-panel dataSchema: the fields each result frame produced ({ name, type, labels }), for targeting field names in transformations or byName overrides",
      "type": "boolean",
    },
    "includeStatus": {
      "default": false,
      "description": "When true, include per-panel runtime status: loadingState, hasError, hasNoData, a structured errors array (source query/plugin/notice, message, refId/type), and info/warning notices",
      "type": "boolean",
    },
  },
  "required": [
    "evaluateVariables",
    "includeStatus",
    "includeSchema",
  ],
  "type": "object",
}
`;

