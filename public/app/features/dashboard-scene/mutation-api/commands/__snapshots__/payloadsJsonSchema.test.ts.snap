exports[`mutation command payloads — JSON Schema contract movePanel payload JSON Schema is stable 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Move a panel to a different group or reposition within the current group",
  "properties": {
    "element": {
      "additionalProperties": false,
      "description": "Element to move, identified by name",
      "properties": {
        "kind": {
          "const": "ElementReference",
          "default": "ElementReference",
          "type": "string",
        },
        "name": {
          "description": "Element key in the dashboard elements map",
          "type": "string",
        },
      },
      "required": [
        "kind",
        "name",
      ],
      "type": "object",
    },
    "layoutItem": {
      "additionalProperties": false,
      "description": "Layout item with sizing hints. The kind is adapted to match the target layout (warning emitted if converted). If omitted, preserves current dimensions.",
      "properties": {
        "kind": {
          "description": "Layout item type hint. If omitted, automatically determined from the target layout. A warning is emitted if the provided kind does not match the target layout.",
          "enum": [
            "GridLayoutItem",
            "AutoGridLayoutItem",
          ],
          "type": "string",
        },
        "spec": {
          "additionalProperties": false,
          "default": {},
          "properties": {
            "conditionalRendering": {
              "additionalProperties": false,
              "description": "Show/hide rules (Auto grid layout only). On ADD_PANEL, ignored with a warning if the target is not Auto grid. On UPDATE_PANEL, returns an error.",
              "properties": {
                "kind": {
                  "const": "ConditionalRenderingGroup",
                  "default": "ConditionalRenderingGroup",
                  "type": "string",
                },
                "spec": {
                  "additionalProperties": false,
                  "properties": {
                    "condition": {
                      "description": ""and" = match all rules; "or" = match any rule",
                      "enum": [
                        "and",
                        "or",
                      ],
                      "type": "string",
                    },
                    "items": {
                      "description": "List of conditions. Pass an empty array to remove all rules.",
                      "items": {
                        "oneOf": [
                          {
                            "additionalProperties": false,
                            "properties": {
                              "kind": {
                                "const": "ConditionalRenderingVariable",
                                "type": "string",
                              },
                              "spec": {
                                "additionalProperties": false,
                                "properties": {
                                  "operator": {
                                    "enum": [
                                      "equals",
                                      "notEquals",
                                      "matches",
                                      "notMatches",
                                    ],
                                    "type": "string",
                                  },
                                  "value": {
                                    "description": "Value to compare against. For matches/notMatches this is a regex.",
                                    "type": "string",
                                  },
                                  "variable": {
                                    "description": "Name of the dashboard template variable",
                                    "type": "string",
                                  },
                                },
                                "required": [
                                  "variable",
                                  "operator",
                                  "value",
                                ],
                                "type": "object",
                              },
                            },
                            "required": [
                              "kind",
                              "spec",
                            ],
                            "type": "object",
                          },
                          {
                            "additionalProperties": false,
                            "properties": {
                              "kind": {
                                "const": "ConditionalRenderingData",
                                "type": "string",
                              },
                              "spec": {
                                "additionalProperties": false,
                                "properties": {
                                  "value": {
                                    "description": "true = "has data", false = "no data"",
                                    "type": "boolean",
                                  },
                                },
                                "required": [
                                  "value",
                                ],
                                "type": "object",
                              },
                            },
                            "required": [
                              "kind",
                              "spec",
                            ],
                            "type": "object",
                          },
                          {
                            "additionalProperties": false,
                            "properties": {
                              "kind": {
                                "const": "ConditionalRenderingTimeRangeSize",
                                "type": "string",
                              },
                              "spec": {
                                "additionalProperties": false,
                                "properties": {
                                  "value": {
                                    "description": "Duration threshold (e.g. "5m", "1h", "7d", "6M", "1y")",
                                    "type": "string",
                                  },
                                },
                                "required": [
                                  "value",
                                ],
                                "type": "object",
                              },
                            },
                            "required": [
                              "kind",
                              "spec",
                            ],
                            "type": "object",
                          },
                        ],
                      },
                      "type": "array",
                    },
                    "visibility": {
                      "description": "Whether to show or hide the element when conditions match",
                      "enum": [
                        "show",
                        "hide",
                      ],
                      "type": "string",
                    },
                  },
                  "required": [
                    "visibility",
                    "condition",
                    "items",
                  ],
                  "type": "object",
                },
              },
              "required": [
                "kind",
                "spec",
              ],
              "type": "object",
            },
            "height": {
              "description": "Height in grid units",
              "type": "number",
            },
            "repeat": {
              "additionalProperties": false,
              "description": "Repeat for each value of a variable",
              "properties": {
                "direction": {
                  "description": "Repeat direction: horizontal or vertical",
                  "enum": [
                    "h",
                    "v",
                  ],
                  "type": "string",
                },
                "maxPerRow": {
                  "description": "Maximum panels per row when direction is "h"",
                  "type": "number",
                },
                "mode": {
                  "const": "variable",
                  "type": "string",
                },
                "value": {
                  "description": "Variable name to repeat by",
                  "type": "string",
                },
              },
              "required": [
                "mode",
                "value",
              ],
              "type": "object",
            },
            "width": {
              "description": "Width in grid columns (1-24)",
              "type": "number",
            },
            "x": {
              "description": "Column position (0-23 in a 24-column grid)",
              "type": "number",
            },
            "y": {
              "description": "Row position",
              "type": "number",
            },
          },
          "type": "object",
        },
      },
      "required": [
        "spec",
      ],
      "type": "object",
    },
    "position": {
      "additionalProperties": false,
      "description": "DEPRECATED: Use layoutItem instead.",
      "properties": {
        "height": {
          "description": "Height in grid units",
          "type": "number",
        },
        "width": {
          "description": "Width in grid columns (1-24)",
          "type": "number",
        },
        "x": {
          "description": "Column position (0-23 in a 24-column grid)",
          "type": "number",
        },
        "y": {
          "description": "Row position",
          "type": "number",
        },
      },
      "type": "object",
    },
    "toParent": {
      "description": "Path to the destination group (e.g., "/rows/1", "/tabs/0/rows/2"). Stays in current group if omitted.",
      "pattern": "^\\/([a-z]+\\/\\d+(\\/[a-z]+\\/\\d+)*)?$",
      "type": "string",
    },
  },
  "required": [
    "element",
  ],
  "type": "object",
}
`;

