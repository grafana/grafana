        "Tooltip",
      ],
      "type": "string",
    },
    "description": {
      "description": "Dashboard description",
      "type": "string",
    },
    "editable": {
      "description": "Whether the dashboard is editable",
      "type": "boolean",
    },
    "links": {
      "description": "Replaces the full dashboard links list. Pass [] to clear all links.",
      "items": {
        "additionalProperties": false,
        "properties": {
          "asDropdown": {
            "description": "Render tag-based links as a dropdown",
            "type": "boolean",
          },
          "icon": {
            "description": "Icon name, e.g. "external link"",
            "type": "string",
          },
          "includeVars": {
            "description": "Append current template variable values to the link",
            "type": "boolean",
          },
          "keepTime": {
            "description": "Append the current time range to the link",
            "type": "boolean",
          },
          "placement": {
            "const": "inControlsMenu",
            "description": "Render the link in the dashboard controls dropdown menu instead of above the panels",
            "type": "string",
          },
          "tags": {
            "description": "Tags used when type is "dashboards"",
            "items": {
              "type": "string",
            },
            "type": "array",
          },
          "targetBlank": {
            "description": "Open in a new tab",
            "type": "boolean",
          },
          "title": {
            "description": "Link label shown in the dashboard top bar",
            "type": "string",
          },
          "tooltip": {
            "description": "Hover tooltip",
            "type": "string",
          },
          "type": {
            "default": "link",
            "description": "Link type: "link" (single URL) or "dashboards" (by tags)",
            "enum": [
              "link",
              "dashboards",
            ],
            "type": "string",
          },
          "url": {
            "description": "Link target URL (required when type is "link")",
            "type": "string",
          },
        },
        "required": [
          "title",
          "type",
        ],
        "type": "object",
      },
      "type": "array",
    },
    "liveNow": {
      "description": "Continuously redraw panels to keep live data moving left",
      "type": "boolean",
    },
    "preload": {
      "description": "Load all panels when the dashboard loads",
      "type": "boolean",
    },
    "tags": {
      "description": "Dashboard tags",
      "items": {
        "type": "string",
      },
      "type": "array",
    },
    "timeSettings": {
      "additionalProperties": false,
      "description": "Dashboard time settings. Partial update: only the provided fields change.",
      "properties": {
        "autoRefresh": {
          "description": "Auto-refresh interval (e.g. "5s", "1m", "5m", "15m", "30m", "1h", "2h", "1d", "" to disable)",
          "type": "string",
        },
        "from": {
          "description": "Start of time range (e.g. "now-6h")",
          "type": "string",
        },
        "timezone": {
          "description": "Timezone ("browser", "utc", or IANA timezone)",
          "type": "string",
        },
        "to": {
          "description": "End of time range (e.g. "now")",
          "type": "string",
        },
      },
      "type": "object",
    },
    "title": {
      "description": "Dashboard title",
      "type": "string",
    },
  },
  "type": "object",
}
`;

exports[`mutation command payloads — JSON Schema contract updateLayout payload JSON Schema is stable 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Update the layout type and/or properties at a given path",
  "properties": {
    "layoutType": {
      "description": "Target layout type. If omitted, keeps current type and just applies options. Group conversions: RowsLayout <-> TabsLayout. Grid conversions: GridLayout <-> AutoGridLayout.",
      "enum": [
        "RowsLayout",
        "TabsLayout",
        "GridLayout",
        "AutoGridLayout",
      ],
      "type": "string",
    },
    "options": {
      "additionalProperties": false,
      "description": "AutoGridLayout properties. Rejected for other layout types.",
      "properties": {
        "columnWidth": {
          "description": "Custom column width in pixels (only used when columnWidthMode is "custom")",
          "type": "number",
        },
        "columnWidthMode": {
          "description": "Column width preset. Use "custom" with columnWidth for pixel values.",
          "enum": [
            "narrow",
            "standard",
            "wide",
            "custom",
          ],
          "type": "string",
        },
        "fillScreen": {
          "description": "Whether the grid fills the viewport height",
          "type": "boolean",
        },
        "maxColumnCount": {
          "description": "Maximum number of columns",
          "type": "number",
        },
        "rowHeight": {
          "description": "Custom row height in pixels (only used when rowHeightMode is "custom")",
          "type": "number",
        },
        "rowHeightMode": {
          "description": "Row height preset. Use "custom" with rowHeight for pixel values.",
          "enum": [
            "short",
            "standard",
            "tall",
            "custom",
          ],
          "type": "string",
        },
      },
      "type": "object",
    },
    "path": {
      "description": "Path to the layout node (e.g. "/", "/rows/0", "/tabs/0")",
      "pattern": "^\\/([a-z]+\\/\\d+(\\/[a-z]+\\/\\d+)*)?$",
      "type": "string",
    },
  },
  "required": [
    "path",
  ],
  "type": "object",
}
`;

