{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Add a new tab to the dashboard layout",
  "properties": {
    "parentPath": {
      "default": "/",
      "description": "Path to the parent container. "/" for root, or e.g. "/rows/0" to add inside a row.",
      "pattern": "^\\/([a-z]+\\/\\d+(\\/[a-z]+\\/\\d+)*)?$",
      "type": "string",
    },
    "position": {
      "description": "Zero-based index within the parent to insert at (appends if omitted)",
      "type": "number",
    },
    "tab": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "TabsLayoutTab",
          "default": "TabsLayoutTab",
          "type": "string",
        },
        "spec": {
          "additionalProperties": false,
          "properties": {
            "conditionalRendering": {
              "additionalProperties": false,
              "description": "Show/hide rules for this tab",
              "properties": {
                "kind": {
                  "const": "ConditionalRenderingGroup",
                  "default": "ConditionalRenderingGroup",
                  "type": "string",
                },
                "spec": {
                  "additionalProperties": false,
                  "properties": {
                    "condition": {
                      "description": ""and" = match all rules; "or" = match any rule",
                      "enum": [
                        "and",
                        "or",
                      ],
                      "type": "string",
                    },
                    "items": {
                      "description": "List of conditions. Pass an empty array to remove all rules.",
                      "items": {
                        "oneOf": [
                          {
                            "additionalProperties": false,
