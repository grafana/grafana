              "additionalProperties": false,
              "properties": {
                "exclude": {
                  "description": "When true, the listed panels are excluded; otherwise only those panels show the annotation",
                  "type": "boolean",
                },
                "ids": {
                  "description": "Panel IDs to include or exclude (replaces existing array)",
                  "items": {
                    "type": "number",
                  },
                  "type": "array",
                },
