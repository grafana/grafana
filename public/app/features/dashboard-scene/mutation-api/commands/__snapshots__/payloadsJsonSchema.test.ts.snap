exports[`mutation command payloads — JSON Schema contract addRow payload JSON Schema is stable 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Add a new row to the dashboard layout",
  "properties": {
    "parentPath": {
      "default": "/",
      "description": "Path to the parent container. "/" for root, or e.g. "/tabs/0" to add inside a tab.",
      "pattern": "^\\/([a-z]+\\/\\d+(\\/[a-z]+\\/\\d+)*)?$",
      "type": "string",
    },
    "position": {
      "description": "Zero-based index within the parent to insert at (appends if omitted)",
      "type": "number",
    },
    "row": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "RowsLayoutRow",
          "default": "RowsLayoutRow",
          "type": "string",
        },
        "spec": {
          "additionalProperties": false,
          "properties": {
            "collapse": {
              "default": false,
              "description": "Whether the row starts collapsed",
              "type": "boolean",
            },
            "conditionalRendering": {
              "additionalProperties": false,
              "description": "Show/hide rules for this row",
              "properties": {
                "kind": {
                  "const": "ConditionalRenderingGroup",
                  "default": "ConditionalRenderingGroup",
                  "type": "string",
                },
                "spec": {
                  "additionalProperties": false,
                  "properties": {
                    "condition": {
                      "description": ""and" = match all rules; "or" = match any rule",
                      "enum": [
                        "and",
                        "or",
                      ],
                      "type": "string",
                    },
