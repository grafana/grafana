exports[`mutation command payloads — JSON Schema contract addAnnotation payload JSON Schema is stable 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Add a new dashboard annotation layer",
  "properties": {
    "annotation": {
      "additionalProperties": false,
      "description": "Annotation definition (AnnotationQueryKind)",
      "properties": {
        "kind": {
          "const": "AnnotationQuery",
          "type": "string",
        },
        "spec": {
          "additionalProperties": false,
          "properties": {
            "builtIn": {
              "type": "boolean",
            },
            "enable": {
              "default": true,
              "type": "boolean",
            },
            "filter": {
              "additionalProperties": false,
              "properties": {
                "exclude": {
                  "type": "boolean",
                },
                "ids": {
                  "items": {
                    "type": "number",
                  },
                  "type": "array",
                },
              },
              "required": [
                "ids",
              ],
              "type": "object",
            },
            "hide": {
              "default": false,
              "type": "boolean",
            },
            "iconColor": {
              "default": "red",
              "type": "string",
            },
            "legacyOptions": {
              "additionalProperties": {},
              "propertyNames": {
                "type": "string",
              },
              "type": "object",
            },
            "mappings": {
              "additionalProperties": {
                "additionalProperties": false,
                "properties": {
                  "regex": {
                    "type": "string",
                  },
                  "source": {
                    "type": "string",
                  },
                  "value": {
                    "type": "string",
                  },
                },
                "type": "object",
              },
              "propertyNames": {
                "type": "string",
              },
              "type": "object",
            },
            "name": {
              "type": "string",
            },
            "placement": {
              "const": "inControlsMenu",
              "type": "string",
            },
            "query": {
              "additionalProperties": false,
              "properties": {
                "datasource": {
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
                "group": {
                  "type": "string",
                },
                "kind": {
                  "const": "DataQuery",
                  "type": "string",
                },
                "labels": {
                  "additionalProperties": {
                    "type": "string",
                  },
                  "propertyNames": {
                    "type": "string",
                  },
                  "type": "object",
                },
                "spec": {
                  "additionalProperties": {},
                  "propertyNames": {
                    "type": "string",
                  },
                  "type": "object",
                },
                "version": {
                  "default": "v0",
                  "type": "string",
                },
              },
              "required": [
                "kind",
                "group",
                "version",
                "spec",
              ],
              "type": "object",
            },
          },
          "required": [
            "query",
            "enable",
            "hide",
            "iconColor",
            "name",
          ],
          "type": "object",
        },
      },
      "required": [
        "kind",
        "spec",
      ],
      "type": "object",
    },
    "position": {
      "description": "Position in annotations list (optional, appends if not set)",
      "type": "number",
    },
  },
  "required": [
    "annotation",
  ],
  "type": "object",
}
`;

