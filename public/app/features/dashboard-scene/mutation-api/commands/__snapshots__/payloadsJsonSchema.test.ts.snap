                              "kind": {
                                "const": "ConditionalRenderingVariable",
                                "type": "string",
                              },
                              "spec": {
                                "additionalProperties": false,
                                "properties": {
                                  "operator": {
                                    "enum": [
                                      "equals",
                                      "notEquals",
                                      "matches",
                                      "notMatches",
                                    ],
                                    "type": "string",
                                  },
                                  "value": {
                                    "description": "Value to compare against. For matches/notMatches this is a regex.",
                                    "type": "string",
                                  },
                                  "variable": {
                                    "description": "Name of the dashboard template variable",
                                    "type": "string",
                                  },
                                },
                                "required": [
                                  "variable",
                                  "operator",
                                  "value",
                                ],
                                "type": "object",
                              },
                            },
                            "required": [
                              "kind",
                              "spec",
                            ],
                            "type": "object",
                          },
                          {
                            "additionalProperties": false,
                            "properties": {
                              "kind": {
                                "const": "ConditionalRenderingData",
                                "type": "string",
                              },
                              "spec": {
                                "additionalProperties": false,
                                "properties": {
                                  "value": {
                                    "description": "true = "has data", false = "no data"",
                                    "type": "boolean",
                                  },
                                },
                                "required": [
                                  "value",
                                ],
                                "type": "object",
                              },
                            },
                            "required": [
                              "kind",
                              "spec",
                            ],
                            "type": "object",
                          },
                          {
                            "additionalProperties": false,
                            "properties": {
                              "kind": {
                                "const": "ConditionalRenderingTimeRangeSize",
                                "type": "string",
                              },
                              "spec": {
                                "additionalProperties": false,
                                "properties": {
                                  "value": {
                                    "description": "Duration threshold (e.g. "5m", "1h", "7d", "6M", "1y")",
                                    "type": "string",
                                  },
                                },
                                "required": [
                                  "value",
                                ],
                                "type": "object",
                              },
                            },
                            "required": [
                              "kind",
                              "spec",
                            ],
                            "type": "object",
                          },
                        ],
                      },
                      "type": "array",
                    },
                    "visibility": {
                      "description": "Whether to show or hide the element when conditions match",
                      "enum": [
                        "show",
                        "hide",
                      ],
                      "type": "string",
                    },
                  },
                  "required": [
                    "visibility",
                    "condition",
                    "items",
                  ],
                  "type": "object",
                },
              },
              "required": [
                "kind",
