  "description": "Update an existing dashboard annotation layer by name (partial update, deep-merge)",
  "properties": {
    "annotation": {
      "additionalProperties": false,
      "description": "Partial annotation update. Only provided fields are applied. Object fields are deep-merged. Arrays (e.g. filter.ids) are replaced wholesale.",
      "properties": {
        "kind": {
          "const": "AnnotationQuery",
