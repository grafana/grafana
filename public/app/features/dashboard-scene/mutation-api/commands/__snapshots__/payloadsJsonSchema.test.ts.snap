                "type": "string",
              },
              "type": "object",
            },
            "mappings": {
              "additionalProperties": {
                "additionalProperties": false,
                "properties": {
                  "regex": {
                    "description": "Regular expression applied to the field value",
                    "type": "string",
                  },
                  "source": {
                    "description": "Source type for the field value (e.g., "field", "text")",
                    "type": "string",
                  },
                  "value": {
                    "description": "Constant value to use when source is "text"",
                    "type": "string",
                  },
                },
                "type": "object",
              },
              "propertyNames": {
                "type": "string",
              },
              "type": "object",
            },
            "name": {
              "description": "Rename the annotation. Must remain unique within the dashboard.",
              "type": "string",
            },
            "placement": {
              "const": "inControlsMenu",
              "type": "string",
            },
            "query": {
              "additionalProperties": false,
              "description": "Partial query update; deep-merged into existing query.",
              "properties": {
                "datasource": {
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                    },
                  },
                  "type": "object",
                },
                "group": {
                  "description": "Datasource type (e.g., "prometheus", "loki", "grafana")",
                  "type": "string",
                },
                "kind": {
                  "const": "DataQuery",
                  "type": "string",
                },
                "spec": {
                  "additionalProperties": {},
                  "description": "Query-specific fields. Deep-merged into the existing query spec.",
                  "propertyNames": {
                    "type": "string",
                  },
                  "type": "object",
                },
                "version": {
                  "type": "string",
                },
              },
              "type": "object",
            },
          },
          "type": "object",
        },
      },
      "required": [
        "spec",
      ],
      "type": "object",
    },
    "name": {
      "description": "Annotation name to update",
      "type": "string",
    },
  },
  "required": [
    "name",
    "annotation",
  ],
  "type": "object",
}
`;

exports[`mutation command payloads — JSON Schema contract updateDashboardSettings payload JSON Schema is stable 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Update dashboard settings (title, description, tags, editable, cursorSync, links, timeSettings, liveNow, preload)",
