# This file is intentionally empty. It must not be committed to version control.
# Generate a local private key and place it here before starting the devenv.
# Example:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:4096 -out devenv/docker/blocks/auth/authentik/key.pem
# This file is listed in .gitignore to prevent accidental commits.
