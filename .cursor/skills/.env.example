# Git Sync Test Skills — Required Environment Variables
#
# Copy this file to .env and fill in the values.
# On Cursor Cloud, configure these in the dashboard secrets instead.
#
# Which variables you need depends on which skill you're running:
#   test-git-sync-pat          → GitHub PAT variables only
#   test-git-sync-gitlab      → GitLab token variables only
#   test-git-sync-bitbucket   → Bitbucket token variables only
#   test-git-sync-github-app  → GitHub App variables only
#   test-git-sync-resource-ops → GitHub PAT variables only
#   test-git-sync-none-role  → GitHub PAT variables only
#   test-git-sync-all         → GitHub PAT required; GitLab, Bitbucket, GitHub App optional

# ── GitHub PAT Flow (test-git-sync-pat, test-git-sync-resource-ops, test-git-sync-all) ──

# GitHub repo URL — must be a repo you own or have push access to.
# The test skill will create provisioned folders/dashboards backed by this repo.
GIT_SYNC_TEST_PAT_REPO_URL=https://github.com/owner/repo

# GitHub Personal Access Token — needs repo (read/write) scope.
GIT_SYNC_TEST_PAT=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitLab Token Flow (test-git-sync-gitlab) ──

# GitLab repo URL — must be a repo you own or have push access to.
GIT_SYNC_TEST_GITLAB_REPO_URL=https://gitlab.com/owner/repo

# GitLab Project Access Token — needs repository read/write permissions.
GIT_SYNC_TEST_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Bitbucket Token Flow (test-git-sync-bitbucket) ──

# Bitbucket repo URL — must be a repo you own or have push access to.
GIT_SYNC_TEST_BITBUCKET_REPO_URL=https://bitbucket.org/owner/repo

# Bitbucket API Token — needs repository read/write permissions.
GIT_SYNC_TEST_BITBUCKET_TOKEN=ATATTxxxxxxxxxxxxxxxx

# Bitbucket username paired with the API token.
GIT_SYNC_TEST_BITBUCKET_TOKEN_USER=workspace-user

# ── GitHub App Flow (test-git-sync-github-app, test-git-sync-all) ──

# GitHub repo URL for the App flow — can be the same repo or a different one.
GIT_SYNC_TEST_APP_REPO_URL=https://github.com/owner/repo

# GitHub App ID (numeric).
GIT_SYNC_TEST_GITHUB_APP_ID=123456

# GitHub App Installation ID (numeric).
GIT_SYNC_TEST_GITHUB_APP_INSTALLATION_ID=12345678

# GitHub App private key — provide ONE of the two options below:

# Option A (local): Path to the PEM private key file on disk.
GIT_SYNC_TEST_GITHUB_APP_PRIVATE_KEY_PATH=/path/to/private-key.pem

# Option B (cloud): PEM private key content directly (for Cursor Cloud secrets).
# GIT_SYNC_TEST_GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----