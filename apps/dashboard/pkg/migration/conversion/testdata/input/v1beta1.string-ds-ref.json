{
  "kind": "Dashboard",
  "apiVersion": "dashboard.grafana.app/v1beta1",
  "metadata": {
    "name": "string-ds-ref"
  },
  "spec": {
    "schemaVersion": 41,
    "title": "String DS Ref (legacy bare strings)",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "timezone": "utc",
    "weekStart": "",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": {
            "type": "grafana",
            "uid": "-- Grafana --"
          },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "templating": {
      "list": [
        {
          "type": "query",
          "name": "query_known",
          "label": "Query (known name)",
          "datasource": "Existing Target Name",
          "query": "label_values(foo)",
          "hide": 0,
          "refresh": 1
        },
        {
          "type": "query",
          "name": "query_unknown",
          "label": "Query (unknown name, preserved as UID-only)",
          "datasource": "UnknownQueryDS",
          "query": "label_values(bar)",
          "hide": 0,
          "refresh": 1
        },
        {
          "type": "datasource",
          "name": "datasource",
          "label": "Datasource",
          "query": "prometheus",
          "current": {
            "selected": false,
            "text": "prom",
            "value": "prom"
          }
        },
        {
          "type": "adhoc",
          "name": "adhoc_known",
          "label": "Adhoc (known name)",
          "datasource": "Existing Target Name"
        },
        {
          "type": "adhoc",
          "name": "adhoc_unknown",
          "label": "Adhoc (unknown name, preserved as UID-only)",
          "datasource": "UnknownAdhocDS"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "Panel: bare-string datasource resolvable via the index",
        "datasource": "Existing Target Name",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "fieldConfig": { "defaults": {}, "overrides": [] },
        "options": {},
        "targets": [
          {
            "refId": "A",
            "datasource": "Existing Target Name",
            "expr": "up"
          }
        ]
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "Panel: bare-string datasource NOT in the index, preserved as UID-only ref",
        "datasource": "UnknownPanelDS",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "fieldConfig": { "defaults": {}, "overrides": [] },
        "options": {},
        "targets": [
          {
            "refId": "A",
            "datasource": "UnknownPanelDS",
            "expr": "up"
          }
        ]
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Panel: template-variable datasource (unchanged behavior)",
        "datasource": "${datasource}",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "fieldConfig": { "defaults": {}, "overrides": [] },
        "options": {},
        "targets": [
          {
            "refId": "A",
            "datasource": "${datasource}",
            "expr": "up"
          }
        ]
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "Panel: \"default\" sentinel resolves to the configured default datasource",
        "datasource": "default",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "fieldConfig": { "defaults": {}, "overrides": [] },
        "options": {},
        "targets": [
          {
            "refId": "A",
            "datasource": "default",
            "expr": "up"
          }
        ]
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "Panel: object datasource ref (unchanged behavior)",
        "datasource": {
          "type": "loki",
          "uid": "non-default-test-ds-uid"
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "fieldConfig": { "defaults": {}, "overrides": [] },
        "options": {},
        "targets": [
          {
            "refId": "A",
            "datasource": {
              "type": "loki",
              "uid": "non-default-test-ds-uid"
            },
            "expr": "{job=\"x\"}"
          }
        ]
      }
    ]
  }
}
