package v0alpha1

// autogenRouteTimings sets the timings on the root of the autogenerated
// (simplified routing) policy so it never inherits them from the user's root
// route. Any field left unset falls back to the Alertmanager route defaults.
ConfigSpec: {
	autogenRouteTimings?: {
		// Prometheus duration strings (e.g. "30s", "5m", "4h").
		group_wait?:      string
		group_interval?:  string
		repeat_interval?: string
	}
}
