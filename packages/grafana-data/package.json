{
  "author": "Grafana Labs",
  "license": "Apache-2.0",
  "name": "@grafana/data",
  "version": "13.0.0-pre",
  "description": "Grafana Data Library",
  "keywords": [
    "typescript"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "http://github.com/grafana/grafana.git",
    "directory": "packages/grafana-data"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@grafana-app/source": "./src/index.ts",
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    },
    "./unstable": {
      "@grafana-app/source": "./src/unstable.ts",
      "types": "./dist/types/unstable.d.ts",
      "import": "./dist/esm/unstable.mjs",
      "require": "./dist/cjs/unstable.cjs"
    },
    "./internal": {
      "@grafana-app/source": "./src/internal/index.ts"
    },
    "./test": {
      "@grafana-app/source": "./test/index.ts"
    },
    "./themes/schema.generated.json": {
      "@grafana-app/source": "./src/themes/schema.generated.json",
      "default": "./dist/esm/themes/schema.generated.json"
    },
    "./themes/definitions/*.json": {
      "@grafana-app/source": "./src/themes/themeDefinitions/*.json",
      "default": "./dist/esm/themes/themeDefinitions/*.json"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "./README.md",
    "./CHANGELOG.md",
    "LICENSE_APACHE2"
  ],
  "scripts": {
    "build": "yarn themes-schema && tsc -p ./tsconfig.build.json && rollup -c rollup.config.ts --configPlugin esbuild",
    "clean": "rimraf ./dist ./compiled ./unstable ./package.tgz",
    "typecheck": "tsc --emitDeclarationOnly false --noEmit",
    "prepack": "cp package.json package.json.bak && node ../../scripts/prepare-npm-package.js",
    "postpack": "mv package.json.bak package.json",
    "themes-schema": "tsx ./scripts/generateSchema.ts"
  },
  "dependencies": {
    "@braintree/sanitize-url": "catalog:",
    "@grafana/i18n": "catalog:",
    "@grafana/schema": "catalog:",
    "@leeoniya/ufuzzy": "catalog:",
    "@types/d3-interpolate": "catalog:",
    "@types/string-hash": "catalog:",
    "@types/systemjs": "catalog:",
    "d3-interpolate": "catalog:",
    "d3-scale-chromatic": "catalog:",
    "date-fns": "catalog:",
    "dompurify": "catalog:",
    "eventemitter3": "catalog:",
    "fast_array_intersect": "catalog:",
    "history": "catalog:",
    "lodash": "catalog:",
    "marked": "catalog:",
    "marked-mangle": "catalog:",
    "moment": "catalog:",
    "moment-timezone": "catalog:",
    "ol": "catalog:",
    "papaparse": "catalog:",
    "react-use": "catalog:",
    "rxjs": "catalog:",
    "string-hash": "catalog:",
    "tinycolor2": "catalog:",
    "tslib": "catalog:",
    "uplot": "catalog:",
    "xss": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@grafana/scenes": "7.1.1",
    "@rollup/plugin-json": "catalog:",
    "@rollup/plugin-node-resolve": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/history": "catalog:",
    "@types/lodash": "catalog:",
    "@types/node": "catalog:",
    "@types/papaparse": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/tinycolor2": "catalog:",
    "esbuild": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "rimraf": "catalog:",
    "rollup": "catalog:",
    "rollup-plugin-copy": "catalog:",
    "rollup-plugin-esbuild": "catalog:",
    "rollup-plugin-node-externals": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
