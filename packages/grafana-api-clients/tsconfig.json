{
  "extends": "../../scripts/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "./",
    "declaration": true,
    "jsx": "react-jsx",
    "declarationDir": "./dist/types",
    "emitDeclarationOnly": true,
    "isolatedModules": true,
    "rootDirs": ["."],
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler"
  },
  "exclude": ["dist/**/*"],
  "include": ["src/**/*.ts*"],
  "ts-node": {
    "swc": true,
    "compilerOptions": {
      "module": "es2020",
      "moduleResolution": "Bundler"
    }
  }
}
