{
  "title": "V2 dashboard with query expressions",
  "tags": [
    "v2",
    "queries"
  ],
  "datasource": [
    {
      "uid": "prom-flat",
      "type": "prometheus"
    },
    {
      "uid": "my-prom"
    },
    {
      "uid": "my-loki"
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "TimeseriesPanel",
      "datasource": [
        {
          "uid": "my-prom"
        }
      ],
      "queries": [
        {
          "refId": "A",
          "datasourceUid": "my-prom",
          "expression": "rate(http_requests_total[5m])"
        }
      ]
    },
    {
      "id": 2,
      "title": "Recent errors",
      "type": "LogsPanel",
      "datasource": [
        {
          "uid": "my-loki"
        }
      ],
      "queries": [
        {
          "refId": "A",
          "datasourceUid": "my-loki",
          "expression": "{app=\"api\"} |= \"error\""
        }
      ]
    },
    {
      "id": 3,
      "title": "Flat-shape query (legacy)",
      "type": "TimeseriesPanel",
      "datasource": [
        {
          "uid": "prom-flat",
          "type": "prometheus"
        }
      ],
      "queries": [
        {
          "refId": "B",
          "datasourceUid": "prom-flat",
          "expression": "up"
        }
      ]
    }
  ],
  "schemaVersion": 0,
  "linkCount": 0,
