                  "status": {
                    "type": "object",
                    "properties": {}
                  }
                }
              }
            },
            "routes": {
              "reload": {
                "get": {
                  "operationId": "reloadThing",
                  "responses": {
                    "200": {
                      "description": "OK"
                    }
                  }
                }
              }
            }
          }
        ]
      }
    ]
  }
