{
  "apiVersion": "apps.grafana.app/v1alpha2",
  "kind": "AppManifest",
  "metadata": {
    "name": "test-app-with-sdk-manifest"
  },
  "spec": {
    "appName": "test-app-with-sdk-manifest",
    "group": "testappwithsdkmanifest.ext.grafana.com",
    "versions": [
      {
        "name": "v1",
        "kinds": [
          {
            "kind": "Thing",
            "plural": "things",
